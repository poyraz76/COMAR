[D-BUS Service]
# 2026 Protokolü: Merkezi "tr.org.pardus.comar" kimliği mühürlendi.
Name=tr.org.pardus.comar

# Çekirdek İcra Yolu: setup.py tarafından kurulan ana ikili dosya.
Exec=/usr/sbin/comar

# Sistem yönetimi (Ağ, Servis, Donanım) için root yetkisi zorunludur.
User=root
